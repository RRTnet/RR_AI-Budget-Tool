# ─────────────────────────────────────────────────────────────────
# WealthTracker — Environment Variables
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# NEVER commit .env to git — it contains secrets!
# ─────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
# When running via Docker Compose, use the service name "postgres"
DATABASE_URL=postgresql://wealthuser:wealthpass@postgres:5432/wealthtracker

# For local development (no Docker):
# DATABASE_URL=postgresql://wealthuser:wealthpass@localhost:5432/wealthtracker

# ── Security ──────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production-please

# ── App settings ──────────────────────────────────────────────────
DEBUG=true
APP_VERSION=1.0.0

# ── CORS Origins ──────────────────────────────────────────────────
# JSON array of allowed origins
CORS_ORIGINS=["http://localhost:9000","http://localhost:3000"]

# ── Ollama / AI Advisor ───────────────────────────────────────────
# host.docker.internal resolves to the host machine from inside Docker
OLLAMA_BASE_URL=http://localhost:8080/
OLLAMA_MODEL=gpt-oss:120b

# ── Twilio SMS & WhatsApp (for daily expense reminders) ───────────
# Sign up at https://www.twilio.com — free trial includes test credits
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+14155238886

# WhatsApp sender — use Twilio sandbox number for testing:
#   Sandbox: whatsapp:+14155238886  (users must join sandbox first)
#   Production: whatsapp:+YOUR_WHATSAPP_BUSINESS_NUMBER
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Reminder defaults ─────────────────────────────────────────────
DEFAULT_REMINDER_TIME=20:00
DEFAULT_TIMEZONE=UTC
